generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Empresa {
  id                 Int                @id @default(autoincrement())
  nombre             String             @unique
  tipo               Programa           @default(AMBAS)
  semaforo           Semaforo           @default(AMBAR)
  scoreV3            Float              @default(0)
  fiabilidadReciente Float              @default(0)
  esComodin          Boolean            @default(false)
  aceptaExtras       Boolean            @default(false)
  maxExtrasTrimestre Int                @default(0)
  prioridadReduccion PrioridadReduccion @default(MEDIA)
  tieneBolsa         Boolean            @default(false)
  turnoPreferido     String?
  activa             Boolean            @default(true)
  esNueva            Boolean            @default(false)
  notas              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  configsTrimestre   ConfigTrimestral[]
  ciudades           EmpresaCiudad[]
  frecuencias        Frecuencia[]
  historico          HistoricoTaller[]
  planificaciones    Planificacion[]
  restricciones      Restriccion[]

  @@map("empresa")
}

model Taller {
  id              Int               @id @default(autoincrement())
  nombre          String
  programa        Programa
  diaSemana       String?
  turno           String?
  esContratante   Boolean           @default(false)
  descripcion     String?
  activo          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  horario         String?
  historico       HistoricoTaller[]
  planificaciones Planificacion[]
  extraSlots      SemanaExtraSlot[]

  @@map("taller")
}

// Annual weekly calendar configuration
// Each row = one week of one year, either "normal" or "intensiva"
// Normal: all 20 base talleres active with default day/horario
// Intensiva: EF afternoon OFF, IT afternoon moved to Wednesday morning
model SemanaConfig {
  id        Int      @id @default(autoincrement())
  anio      Int                          // 2026
  semana    Int                          // 1-52 (ISO week number)
  tipo      String   @default("normal")  // "normal" | "intensiva"
  notas     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  extras    SemanaExtraSlot[]

  @@unique([anio, semana])
  @@index([anio])
  @@map("semana_config")
}

// Extra taller slots for specific weeks (beyond standard configuration)
// Used when a week needs MORE than the standard 20 slots
model SemanaExtraSlot {
  id             Int      @id @default(autoincrement())
  semanaConfigId Int
  tallerId       Int               // References base taller from catalogue
  diaSemana      String?           // Override day (null = use taller's default)
  horario        String?           // Override horario (null = use taller's default)
  notas          String?
  createdAt      DateTime @default(now())

  semanaConfig   SemanaConfig @relation(fields: [semanaConfigId], references: [id], onDelete: Cascade)
  taller         Taller       @relation(fields: [tallerId], references: [id])

  @@index([semanaConfigId])
  @@map("semana_extra_slot")
}

model Ciudad {
  id              Int             @id @default(autoincrement())
  nombre          String          @unique
  activa          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  empresas        EmpresaCiudad[]
  planificaciones Planificacion[]

  @@map("ciudad")
}

model EmpresaCiudad {
  empresaId      Int
  ciudadId       Int
  activaReciente Boolean @default(true)
  ciudad         Ciudad  @relation(fields: [ciudadId], references: [id], onDelete: Cascade)
  empresa        Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@id([empresaId, ciudadId])
  @@map("empresaCiudad")
}

model Restriccion {
  id          Int             @id @default(autoincrement())
  empresaId   Int
  tipo        TipoRestriccion
  clave       String
  valor       String
  descripcion String?
  createdAt   DateTime        @default(now())
  empresa     Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@map("restriccion")
}

model ConfigTrimestral {
  id                     Int          @id @default(autoincrement())
  empresaId              Int
  trimestre              String
  tipoParticipacion      Programa     @default(AMBAS)
  escuelaPropia          Boolean      @default(false)
  frecuenciaSolicitada   Int?
  frecuenciaEF           Int?         // Explicit EF workshops requested (from master import)
  frecuenciaIT           Int?         // Explicit IT workshops requested (from master import)
  disponibilidadDias     String       @default("L,M,X,J,V")
  turnoPreferido         String?
  voluntariosDisponibles Int          @default(0)
  preferenciasTaller     String?
  notas                  String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  empresa                Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  frecuencias            Frecuencia[]

  @@unique([empresaId, trimestre])
  @@index([trimestre])
  @@map("configTrimestral")
}

// Días festivos / no laborables para la planificación
// Se sube una vez al año con todas las fechas festivas
// El solver excluye solo los slots cuyo día coincide con un festivo
model Festivo {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @db.Date            // the actual date (2026-04-02)
  dia       String                        // day letter: L, M, X, J, V (derived from fecha)
  trimestre String                        // which quarter this falls in (2026-Q2)
  semana    Int                           // relative week within quarter (1-13)
  motivo    String?                       // "Jueves Santo", "Navidad", etc.
  createdAt DateTime @default(now())

  @@unique([fecha])                       // one entry per date
  @@map("festivo")
  @@index([trimestre])
}

model Frecuencia {
  id                Int              @id @default(autoincrement())
  configId          Int
  empresaId         Int
  trimestre         String
  talleresEF        Int              @default(0)
  talleresIT        Int              @default(0)
  totalAsignado     Int              @default(0)
  semaforoCalculado Semaforo         @default(AMBAR)
  scoreCalculado    Float            @default(0)
  ajusteDesempeno   Float            @default(0)
  esNueva           Boolean          @default(false)
  createdAt         DateTime         @default(now())
  config            ConfigTrimestral @relation(fields: [configId], references: [id], onDelete: Cascade)
  empresa           Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, trimestre])
  @@index([trimestre])
  @@map("frecuencia")
}

model HistoricoTaller {
  id                Int          @id @default(autoincrement())
  empresaId         Int          // Company that actually did the workshop (final)
  empresaIdOriginal Int?         // Company originally assigned by solver (for traceability)
  tallerId          Int
  fecha             DateTime     @db.Date
  estado            EstadoTaller @default(OK)
  ciudad            String?
  trimestre         String?
  motivoCambio      String?      // "EMPRESA_CANCELO" | "DECISION_PLANIFICADOR" | null
  createdAt         DateTime     @default(now())
  empresa           Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  taller            Taller       @relation(fields: [tallerId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([trimestre])
  @@index([fecha])
  @@map("historicoTaller")
}

model Planificacion {
  id                Int            @id @default(autoincrement())
  trimestre         String
  semana            Int
  dia               String
  turno             String?
  empresaId         Int?           // nullable: null = vacancy (current company, may change during operation)
  empresaIdOriginal Int?           // Company assigned by solver (NEVER changes after generation)
  tallerId          Int
  ciudadId          Int?
  tipoAsignacion    TipoAsignacion @default(BASE)
  esContingencia    Boolean        @default(false)
  version           Int            @default(1)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  horario           String?
  estado            String         @default("PLANIFICADO") // PLANIFICADO | CONFIRMADO | OK | CANCELADO | VACANTE
  confirmado        Boolean        @default(false)
  notas             String?
  motivoCambio      String?        // "EMPRESA_CANCELO" | "DECISION_PLANIFICADOR" | null (reason for company change)
  ciudad            Ciudad?        @relation(fields: [ciudadId], references: [id])
  empresa           Empresa?       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  taller            Taller         @relation(fields: [tallerId], references: [id], onDelete: Cascade)

  @@index([trimestre])
  @@index([empresaId])
  @@index([trimestre, semana, dia])
  @@map("planificacion")
}

model SolverLog {
  id                   Int      @id @default(autoincrement())
  trimestre            String
  version              Int      @default(1)
  status               String
  tiempoSegundos       Float    @default(0)
  inviolablesCumplidas Float    @default(0)
  preferentesCumplidas Float    @default(0)
  warnings             String?
  parametros           String?
  createdAt            DateTime @default(now())

  @@index([trimestre])
  @@map("solverLog")
}

enum UserRole {
  USER
  ADMIN
}

enum Programa {
  EF
  IT
  AMBAS
}

enum Semaforo {
  VERDE
  AMBAR
  ROJO
}

enum PrioridadReduccion {
  ALTA
  MEDIA
  BAJA
}

enum TipoRestriccion {
  HARD
  SOFT
}

enum EstadoTaller {
  OK
  CANCELADO
}

enum TipoAsignacion {
  BASE
  EXTRA
  CONTINGENCIA
}

// Global application settings (singleton table with id=1)
model AppSettings {
  id                 Int      @id @default(1)
  trimestreActivo    String   // e.g., "2026-Q2" — the quarter being operated
  trimestreSiguiente String?  // e.g., "2026-Q3" — the quarter being prepared (nullable)
  updatedAt          DateTime @updatedAt

  @@map("appSettings")
}
